generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Autenticação ───────────────────────────────────────────

model Usuario {
  id            String    @id @default(cuid())
  codigo        String    @unique @map("usua_cd_usuario")
  nome          String    @map("usua_tx_nome_usuario")
  email         String?   @unique @map("usua_tx_email_externo")
  senha         String    @map("usua_tx_senha")
  categoria     String?   @map("usua_tx_categoria")
  ativo         Boolean   @default(true)
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  acessos              Acesso[]
  perfis               UsuarioPerfil[]
  mapeamentos          UsuarioMapeamento[]
  historico            UsuarioHistorico[]
  comentarios          ProcessoComentario[]  @relation("ComentarioAutor")
  versoesCriadas       MegaProcessoVersao[]  @relation("VersaoAutor")
  megaProcessosResp    MegaProcesso[]        @relation("MegaProcessoResponsavel")
  pessoa               Pessoa?

  @@map("usuario")
}

model Acesso {
  id             String       @id @default(cuid())
  usuarioId      String       @map("usuario_id")
  megaProcessoId Int          @map("mega_processo_id")
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id])

  @@unique([usuarioId, megaProcessoId])
  @@map("acesso")
}

model Perfil {
  id        Int           @id @default(autoincrement()) @map("perf_cd_perfil")
  descricao String        @map("perf_tx_desc_perfil")

  usuarios  UsuarioPerfil[]

  @@map("perfil")
}

model UsuarioPerfil {
  usuarioId String   @map("usuario_id")
  perfilId  Int      @map("perfil_id")
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  perfil    Perfil   @relation(fields: [perfilId], references: [id])

  @@id([usuarioId, perfilId])
  @@map("usuario_perfil")
}

// ─── Cadeia de Valor ─────────────────────────────────────────────

model CadeiaValor {
  id           Int       @id @default(autoincrement())
  descricao    String
  abreviacao   String?
  posicaoX     Float     @default(0) @map("posicao_x")
  posicaoY     Float     @default(0) @map("posicao_y")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  macroprocessos MegaProcesso[]

  @@map("cadeia_valor")
}

// ─── Hierarquia de Processos ─────────────────────────────────────

model MegaProcesso {
  id              Int      @id @default(autoincrement()) @map("mepr_cd_mega_processo")
  descricao       String   @map("mepr_tx_desc_mega_processo")
  abreviacao      String?  @map("mepr_tx_abrevia")
  abreviacaoCurso String?  @map("mepr_tx_abrevia_curso")
  bloqueado       Boolean  @default(false) @map("mepr_in_bloqueado")
  bloqueadoPerfil Boolean  @default(false) @map("mepr_in_bloqueado_perfil")
  descricaoLonga  String?  @map("mepr_tx_descricao") @db.Text
  status          String   @default("Publicado") @map("mepr_tx_status")
  responsavelId   String?  @map("responsavel_id")
  cadeiaValorId   Int?     @map("cadeia_valor_id")
  posicaoX        Float    @default(0) @map("posicao_x")
  posicaoY        Float    @default(0) @map("posicao_y")
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  processos       Processo[]
  acessos         Acesso[]
  transacoes      TransacaoMega[]
  mapeamentos     UsuarioMapeamento[]
  comentarios     ProcessoComentario[]
  versoes         MegaProcessoVersao[]
  riscos          ProcessoRisco[]
  responsavel     Usuario?             @relation("MegaProcessoResponsavel", fields: [responsavelId], references: [id])
  cadeiaValor     CadeiaValor?         @relation(fields: [cadeiaValorId], references: [id], onDelete: SetNull)

  @@index([cadeiaValorId])
  @@map("mega_processo")
}

model Processo {
  id             Int          @id @default(autoincrement()) @map("proc_cd_processo")
  megaProcessoId Int          @map("mega_processo_id")
  descricao      String       @map("proc_tx_desc_processo")
  sequencia      Int?         @map("proc_nr_sequencia")
  tempoMedioCiclo Float?      @map("proc_nr_tempo_medio")
  custoEstimado   Float?      @map("proc_nr_custo")
  volumeMensal    Int?        @map("proc_nr_volume")
  posicaoX        Float       @default(0) @map("posicao_x")
  posicaoY        Float       @default(0) @map("posicao_y")
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id])
  subProcessos   SubProcesso[]
  transacoes     TransacaoProcesso[]
  cenarios       CenarioProcesso[]
  raciAtribuicoes RaciAtribuicao[]

  @@map("processo")
}

model SubProcesso {
  id             Int       @id @default(autoincrement()) @map("supr_cd_sub_processo")
  megaProcessoId Int       @map("mega_processo_id")
  processoId     Int       @map("processo_id")
  descricao      String    @map("supr_tx_desc_sub_processo")
  sequencia      Int?      @map("supr_nr_sequencia")
  impacto        Int?      @map("supr_tx_impacto")
  posicaoX       Float     @default(0) @map("posicao_x")
  posicaoY       Float     @default(0) @map("posicao_y")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  processo       Processo  @relation(fields: [processoId], references: [id])
  empresas       SubProcessoEmpresa[]
  atividades     AtividadeCarga[]
  atividadesMapa Atividade[]

  @@map("sub_processo")
}

model Atividade {
  id            Int          @id @default(autoincrement())
  subProcessoId Int          @map("sub_processo_id")
  descricao     String
  sequencia     Int?
  posicaoX      Float        @default(0) @map("posicao_x")
  posicaoY      Float        @default(0) @map("posicao_y")
  criadoEm      DateTime     @default(now()) @map("criado_em")
  atualizadoEm  DateTime     @updatedAt @map("atualizado_em")

  subProcesso   SubProcesso  @relation(fields: [subProcessoId], references: [id], onDelete: Cascade)
  transacoes    TransacaoAtividade[]
  cenarios      CenarioAtividade[]

  @@index([subProcessoId])
  @@map("atividade")
}

model Transacao {
  id           String   @id @map("tran_cd_transacao")
  descricao    String?  @map("tran_tx_desc_transacao")
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  megaProcessos    TransacaoMega[]
  atividadesCarga  AtividadeCarga[]
  cenarios         CenarioTransacao[]
  processos        TransacaoProcesso[]
  atividades       TransacaoAtividade[]

  @@map("transacao")
}

model TransacaoMega {
  transacaoId    String       @map("transacao_id")
  megaProcessoId Int          @map("mega_processo_id")
  criadoEm     DateTime     @default(now()) @map("criado_em")

  transacao      Transacao    @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id], onDelete: Cascade)

  @@id([transacaoId, megaProcessoId])
  @@map("transacao_mega")
}

model TransacaoProcesso {
  transacaoId String    @map("transacao_id")
  processoId  Int       @map("processo_id")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  transacao   Transacao @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  processo    Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@id([transacaoId, processoId])
  @@index([processoId])
  @@map("transacao_processo")
}

model TransacaoAtividade {
  transacaoId String    @map("transacao_id")
  atividadeId Int       @map("atividade_id")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  transacao   Transacao @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@id([transacaoId, atividadeId])
  @@index([atividadeId])
  @@map("transacao_atividade")
}

// ─── Módulos ──────────────────────────────────────────────────────────────

model Modulo {
  id           Int       @id @default(autoincrement()) @map("modu_cd_modulo")
  descricao    String    @map("modu_tx_desc_modulo")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  subModulos   SubModulo[]

  @@map("modulo")
}

model SubModulo {
  id           Int      @id @default(autoincrement()) @map("sumo_nr_cd_sequencia")
  moduloId     Int?     @map("modulo_id")
  descricao    String   @map("sumo_tx_desc_sub_modulo")
  abreviacao   String?  @map("sumo_tx_abrev")
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  modulo       Modulo?  @relation(fields: [moduloId], references: [id])

  @@map("sub_modulo")
}

// ─── Empresa / Unidade ────────────────────────────────────────────

model EmpresaUnidade {
  id           Int       @id @default(autoincrement()) @map("empr_cd_nr_empresa")
  nome         String    @map("empr_tx_nome_empresa")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  subProcessos SubProcessoEmpresa[]

  @@map("empresa_unidade")
}

model SubProcessoEmpresa {
  subProcessoId Int            @map("sub_processo_id")
  empresaId     Int            @map("empresa_id")
  criadoEm    DateTime       @default(now()) @map("criado_em")

  subProcesso   SubProcesso    @relation(fields: [subProcessoId], references: [id])
  empresa       EmpresaUnidade @relation(fields: [empresaId], references: [id])

  @@id([subProcessoId, empresaId])
  @@map("sub_processo_empresa")
}

// ─── Atividades de carga (legado) ───────────────────────────────────

model AtividadeCarga {
  id            Int         @id @default(autoincrement()) @map("atca_cd_atividade_carga")
  subProcessoId Int         @map("sub_processo_id")
  transacaoId   String?     @map("transacao_id")
  descricao     String?     @map("atca_tx_desc_atividade")
  sequencia     Int?        @map("atca_nr_sequencia")
  criadoEm    DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime    @updatedAt @map("atualizado_em")

  subProcesso   SubProcesso @relation(fields: [subProcessoId], references: [id])
  transacao     Transacao?  @relation(fields: [transacaoId], references: [id])

  @@map("atividade_carga")
}

// ─── Cenários ──────────────────────────────────────────────────────────────

model Cenario {
  id           Int       @id @default(autoincrement()) @map("cena_cd_cenario")
  descricao    String    @map("cena_tx_desc_cenario")
  situacao     String?   @map("cena_tx_situacao")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  transacoes   CenarioTransacao[]
  processos    CenarioProcesso[]
  atividades   CenarioAtividade[]

  @@map("cenario")
}

model CenarioTransacao {
  cenarioId   Int       @map("cenario_id")
  transacaoId String    @map("transacao_id")
  criadoEm   DateTime  @default(now()) @map("criado_em")

  cenario     Cenario   @relation(fields: [cenarioId], references: [id], onDelete: Cascade)
  transacao   Transacao @relation(fields: [transacaoId], references: [id], onDelete: Cascade)

  @@id([cenarioId, transacaoId])
  @@map("cenario_transacao")
}

model CenarioProcesso {
  cenarioId  Int      @map("cenario_id")
  processoId Int      @map("processo_id")
  criadoEm   DateTime @default(now()) @map("criado_em")

  cenario    Cenario  @relation(fields: [cenarioId], references: [id], onDelete: Cascade)
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@id([cenarioId, processoId])
  @@index([processoId])
  @@map("cenario_processo")
}

model CenarioAtividade {
  cenarioId   Int       @map("cenario_id")
  atividadeId Int       @map("atividade_id")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  cenario     Cenario   @relation(fields: [cenarioId], references: [id], onDelete: Cascade)
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@id([cenarioId, atividadeId])
  @@index([atividadeId])
  @@map("cenario_atividade")
}

// ─── BPM: Ciclo de Vida, Comentários, Riscos ──────────────────────

model ProcessoComentario {
  id             String       @id @default(cuid())
  megaProcessoId Int          @map("mega_processo_id")
  usuarioId      String       @map("usuario_id")
  texto          String       @map("texto") @db.Text
  parentId       String?      @map("parent_id")
  criadoEm      DateTime     @default(now()) @map("criado_em")

  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id], onDelete: Cascade)
  usuario        Usuario      @relation("ComentarioAutor", fields: [usuarioId], references: [id])
  respostas      ProcessoComentario[] @relation("ComentarioThread")
  parent         ProcessoComentario?  @relation("ComentarioThread", fields: [parentId], references: [id])

  @@map("processo_comentario")
}

model MegaProcessoVersao {
  id             String       @id @default(cuid())
  megaProcessoId Int          @map("mega_processo_id")
  versao         Int          @map("versao_nr")
  statusAnterior String       @map("status_anterior")
  statusNovo     String       @map("status_novo")
  criadoEm      DateTime     @default(now()) @map("criado_em")
  criadoPorId   String       @map("criado_por_id")

  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id], onDelete: Cascade)
  criadoPor      Usuario      @relation("VersaoAutor", fields: [criadoPorId], references: [id])

  @@map("mega_processo_versao")
}

model ProcessoRisco {
  id             String       @id @default(cuid())
  megaProcessoId Int          @map("mega_processo_id")
  descricao      String       @map("risco_descricao") @db.Text
  probabilidade  String       @default("M") @map("risco_probabilidade")
  impacto        String       @default("M") @map("risco_impacto")
  controle       String?      @map("risco_controle") @db.Text
  criadoEm      DateTime     @default(now()) @map("criado_em")

  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id], onDelete: Cascade)

  @@map("processo_risco")
}

// ─── Auditoria ─────────────────────────────────────────────────────────

model UsuarioMapeamento {
  id             String       @id @default(cuid())
  usuarioId      String       @map("usuario_id")
  megaProcessoId Int          @map("mega_processo_id")
  observacao     String?      @map("observacao") @db.Text
  criadoEm     DateTime     @default(now()) @map("criado_em")

  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  megaProcesso   MegaProcesso @relation(fields: [megaProcessoId], references: [id])

  @@map("usuario_mapeamento")
}

model UsuarioHistorico {
  id         String   @id @default(cuid())
  usuarioId  String   @map("usuario_id")
  operacao   String   @map("operacao")
  descricao  String?  @map("descricao") @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("usuario_historico")
}

// ─── RACI: Áreas, Funções, Pessoas ────────────────────────────────

model Area {
  id           Int       @id @default(autoincrement())
  codigo       String    @unique
  descricao    String
  parentId     Int?      @map("parent_id")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  parent       Area?     @relation("AreaHierarquia", fields: [parentId], references: [id], onDelete: SetNull)
  filhas       Area[]    @relation("AreaHierarquia")
  funcoes      Funcao[]
  pessoas      Pessoa[]

  @@index([parentId])
  @@map("area")
}

model Funcao {
  id           Int       @id @default(autoincrement())
  codigo       String    @unique
  descricao    String
  areaId       Int?      @map("area_id")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  area         Area?     @relation(fields: [areaId], references: [id], onDelete: SetNull)
  pessoas      Pessoa[]

  @@index([areaId])
  @@map("funcao")
}

model Pessoa {
  id           Int       @id @default(autoincrement())
  codigo       String    @unique
  nome         String
  email        String?   @unique
  areaId       Int?      @map("area_id")
  funcaoId     Int?      @map("funcao_id")
  usuarioId    String?   @unique @map("usuario_id")
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  area         Area?     @relation(fields: [areaId], references: [id], onDelete: SetNull)
  funcao       Funcao?   @relation(fields: [funcaoId], references: [id], onDelete: SetNull)
  usuario      Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  raciAtribuicoes RaciAtribuicao[]

  @@index([areaId])
  @@index([funcaoId])
  @@map("pessoa")
}

model RaciAtribuicao {
  id           String    @id @default(cuid())
  processoId   Int       @map("processo_id")
  pessoaId     Int       @map("pessoa_id")
  papel        String    // R | A | C | I
  criadoEm     DateTime  @default(now()) @map("criado_em")

  processo     Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  pessoa       Pessoa    @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@unique([processoId, pessoaId, papel])
  @@index([processoId])
  @@index([pessoaId])
  @@map("raci_atribuicao")
}
