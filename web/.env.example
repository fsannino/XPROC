# ─── Supabase ────────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → Database → Connection string

# Pooler (Session mode, porta 6543) — usado pela aplicação em produção
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Direct (porta 5432) — usado pelas migrations (prisma migrate dev / deploy)
DIRECT_URL="postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO. App não inicia sem isso. Mínimo 32 chars.
# Gerar com: openssl rand -base64 64
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-forte"
NEXTAUTH_URL="http://localhost:3000"

# ─── Security: CSP Report-Only ───────────────────────────────────────────────────
# CSP esta em modo report-only por padrao (so observa violacoes, nao bloqueia).
# Para DESLIGAR (troubleshooting): CSP_REPORT_ONLY=off
# Para coletar violacoes em endpoint: CSP_REPORT_URI="https://seu-endpoint/csp"
# CSP_REPORT_ONLY=off
# CSP_REPORT_URI=
